<!DOCTYPE html>

<title>Activity</title>

{% block body %}
    <h1>Activity</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ activity.id }}</td>
            </tr>
            <tr>
                <th>Subject</th>
                <td>{{ activity.subject }}</td>
            </tr>
            <tr>
                <th>ActivityType</th>
                <td>{{ activity.activityType }}</td>
            </tr>
            <tr>
                <th>Priority</th>
                <td>{{ activity.priority }}</td>
            </tr>
            <tr>
                <th>Direction</th>
                <td>{{ activity.direction }}</td>
            </tr>
            <tr>
                <th>Scheduled_at</th>
                <td>{{ activity.scheduledAt ? activity.scheduledAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Due_date</th>
                <td>{{ activity.dueDate ? activity.dueDate|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Completed_at</th>
                <td>{{ activity.completedAt ? activity.completedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Type d'activité</th>
                <td>{{ activity.activityTypeEnum.label : "—" }}</td>
            </tr>

                            
        </tbody>
    </table>

    <a href="{{ path('app_activity_index') }}">back to list</a>

    <a href="{{ path('app_activity_edit', {'id': activity.id}) }}">edit</a>

    {{ include('activity/_delete_form.html.twig') }}
{% endblock %}
